rules_version = '2';

// Firebase Storage security rules for Barter9911.mn
// Deploy with:  firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {

    // Listing images live under listings/{userId}/...
    // Anyone can view them; only the owner can upload, and only images < 5 MB.
    match /listings/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
